# Get a token from @BotFather on Telegram and paste it here.
# IMPORTANT: never commit your real token. Keep it in your local .env
# (which is gitignored) and only put a placeholder in .env.example.
TELEGRAM_BOT_TOKEN=

# Optional: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Local Bot API Server (optional) ---
# Running your own `telegram-bot-api` server lifts the upload cap from
# 50 MB to 2 GB. Set these to point the bot at a self-hosted instance.
# See README → "Local Bot API Server".
#TELEGRAM_API_BASE_URL=http://127.0.0.1:8081/bot
#TELEGRAM_FILE_API_BASE_URL=http://127.0.0.1:8081/file/bot
